{
    "model": "FwCron",
    "is_dynamic_index": true,
    "list_view": "(SELECT t.*, fk0.iname as [add_users_id_iname], fk1.iname as [upd_users_id_iname] FROM [fwcron] t LEFT OUTER JOIN [users] fk0 ON (fk0.id=t.add_users_id) LEFT OUTER JOIN [users] fk1 ON (fk1.id=t.upd_users_id)) tt",
    "list_sortdef": "iname asc",
    "search_fields": "id iname",
    "related_field_name": "",
    "view_list_defaults": "iname cron cron_human last_run next_run start_date end_date is_running status",
    "view_list_map": {
        "iname": "Job Name",
        "icode": "Sys Code",
        "start_date": "Start Date",
        "end_date": "End Date",
        "add_users_id_iname": "Add User",
        "status": "Status",
        "upd_users_id_iname": "Upd User",
        "upd_time": "Upd Time",
        "idesc": "Description",
        "add_time": "Add Time",
        "id": "ID",
        "cron": "Cron Expression",
        "cron_human": "Cron Expression Human Readable",
        "last_run": "Last Run",
        "next_run": "Next Run",
        "is_running": "Is Running?"
    },
